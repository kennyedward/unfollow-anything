{
  "manifest_version": 3,
  "name": "LinkedIn Page Unfollower",
  "version": "1.0",
  "description": "Automatically unfollow LinkedIn pages you follow",
  "permissions": ["activeTab", "scripting", "storage"],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/*"],
      "js": ["content.js"]
    }
  ]
}
